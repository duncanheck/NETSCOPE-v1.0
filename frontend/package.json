{
  "name": "netscope-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "The NETSCOPE visualizer — a deep-sea bioluminescent organism rendered from the agent's connection state.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "gen:protocol": "cd ../agent && cargo test -p netscope-protocol export_bindings",
    "tauri": "tauri",
    "tauri:dev": "cross-env VITE_TRANSPORT=websocket VITE_AGENT_URL=ws://127.0.0.1:8787/ws tauri dev",
    "tauri:build": "cross-env VITE_TRANSPORT=websocket VITE_AGENT_URL=ws://127.0.0.1:8787/ws tauri build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@react-three/fiber": "^8.17.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
